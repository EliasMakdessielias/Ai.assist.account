{
  "name": "bokpilot-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:auth": "playwright test --project=setup --headed",
    "e2e:smoke": "playwright test --project=noauth",
    "e2e:smoke:auth": "node tests/e2e/require-auth.mjs && playwright test --project=auth tests/e2e/authenticated.smoke.auth.spec.js",
    "e2e:sync": "node tests/e2e/require-auth.mjs && playwright test --project=auth tests/e2e/sync.matrix.auth.spec.js",
    "e2e:cleanup": "node tests/e2e/cleanup.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.26.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  }
}
