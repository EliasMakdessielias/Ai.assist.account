# Supabase Edge Function-secrets (sätt med: supabase secrets set NAME=value).
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY injiceras automatiskt.
# INGA värden checkas in – detta är endast en mall.

# ── Stripe (billing) ──────────────────────────────────────────────
# Aktiverar checkout + webhook. Utan dessa returnerar checkout {configured:false}
# och kunden får supportärende-fallback. Price-id:n läggs på subscription_plans
# (stripe_price_monthly/yearly) via Billing → Planer, inte här.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://app.bokpilot.se/installningar/abonnemang?checkout=success
STRIPE_CANCEL_URL=https://app.bokpilot.se/installningar/abonnemang?checkout=cancel
# Valfria referenser (price-id:n bor primärt i subscription_plans):
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BYRA_MONTHLY=price_...
STRIPE_PRICE_BYRA_YEARLY=price_...

# ── Inbound email (webhook -> documents) ──────────────────────────
INBOUND_EMAIL_WEBHOOK_SECRET=

# ── Notiser ───────────────────────────────────────────────────────
NOTIF_UNSUB_SECRET=          # avregistreringslänk (notif-unsubscribe)
ERROR_REPORT_SECRET=         # HMAC för report-error (IMAP-importern)

# ── AI/OCR ────────────────────────────────────────────────────────
GEMINI_API_KEY=
