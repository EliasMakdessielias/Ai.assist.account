# BokPilot email-kö-processor — kopiera till .env och fyll i. INGA värden checkas in.
# Supabase (service role krävs för att läsa kön + slå upp mottagar-email)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# SMTP (befintlig e-postinfrastruktur, t.ex. Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=underlag@bokpilot.se
SMTP_PASSWORD=
SMTP_FROM=BokPilot <underlag@bokpilot.se>

# Unsubscribe (måste matcha edge function-secret NOTIF_UNSUB_SECRET)
NOTIF_UNSUB_SECRET=
UNSUB_BASE_URL=https://<ref>.supabase.co/functions/v1/notif-unsubscribe

# Hur många notiser per körning
EMAIL_BATCH_SIZE=20
